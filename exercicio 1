 //Escrever um algoritmo para determinar o consumo médio de um automóvel 
 sendo fornecida a distância total percorrida pelo automóvel e o total de combustível gasto.
     
 Algoritmo <consumo_automóvel>
  
 Inicio
  
 Var
 km, comb, consumomedio: real
  
 Escreva ("Qual a distância percorrida pelo automóvel? ")
 Leia (km)
 Escreva ("Qual o total de combustível gasto? ")
 Leia (comb)
 consumomedio <- km / comb 
 Escreva (" O consumo médio percorrido pelo automóvel: " ,consumomedio, "Km/L")

 FimAlgoritmo
